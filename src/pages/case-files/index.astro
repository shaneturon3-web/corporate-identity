---
import { getCollection } from "astro:content";
import D1GalleryBridge from "../../components/gallery/D1GalleryBridge";
import CaseFileFeed from "../../components/mission/CaseFileFeed.astro";
import LivePulse from "../../components/mission/LivePulse.astro";
import type { Role } from "../../lib/auth/roles";
import "../../styles/tokens.css";

const viewerRole = (Astro.url.searchParams.get("role") ?? "PROFESSIONAL_USER") as Role;
const all = await getCollection("projects", ({ data }) => !data.draft);
const projects = all.sort((a, b) => a.data.order - b.data.order);
const staticSlugs = projects.map((p) => p.slug);
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Case Files — Shipyard</title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
</head>
<body class="mission-body">
  <div class="mission-main" style="padding-top: 2rem;">
    <a class="back-link" href="https://shaneturon.ca/">← Institutional root</a>
    <div style="display: flex; flex-wrap: wrap; align-items: center; gap: 1rem; margin: 1rem 0 2rem;">
      <h1 style="margin: 0; font-size: clamp(2rem, 5vw, 3rem); color: var(--accent); letter-spacing: -0.03em;">
        Case Files
      </h1>
      <LivePulse label="Shipyard lab — spine sync" />
    </div>
    <p style="color: var(--muted); margin-bottom: 2rem; max-width: 40rem;">
      Operational case files — Problem → Systems Analysis → Deployment. Console at
      <a href="https://shipyard.shaneturon.ca/console/" style="color: var(--accent)">/console/</a>.
    </p>
    <CaseFileFeed projects={projects} id="gallery-feed" />
    <div id="d1-feed-append" class="mission-main" style="padding: 0; margin-top: -1rem;">
      <D1GalleryBridge client:load role={viewerRole} excludeSlugs={staticSlugs} />
    </div>
  </div>
</body>
</html>
