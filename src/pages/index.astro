---
import { getCollection } from "astro:content";
import ProjectCard from "../components/gallery/ProjectCard.astro";
import "../styles/tokens.css";

const projects = (await getCollection("projects", ({ data }) => !data.draft)).sort(
  (a, b) => a.data.order - b.data.order,
);
const liveCount = projects.filter((p) => p.data.status === "NOW" || p.data.status === "PILOT").length;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Shane Turon | Portfolio & Systems</title>
</head>
<body class="gallery-body">
  <div class="gallery-wrap home-wrap">
    <header class="home-hero">
      <p class="home-kicker">Live portfolio · updated May 2026</p>
      <h1>Shane Turon</h1>
      <p class="home-lead">
        Modular execution portfolio — {projects.length} case files ({liveCount} active pilots).
        This is the product surface; orchestration runs behind ShipYard.
      </p>
      <nav class="home-launch" aria-label="Quick launch">
        <a class="home-launch-primary" href="/projects/">Open full gallery →</a>
        <a href="/professional/dashboard/">ProSpine dashboard</a>
        <a href="/psynova/clinical/">PsyNova clinical</a>
        <a href="https://shipyard.shaneturon.ca/" target="_blank" rel="noopener noreferrer">ShipYard console ↗</a>
      </nav>
    </header>

    <section>
      <h2 class="section-label">Portfolio (what you can click today)</h2>
      <div class="gallery-grid">
        {projects.map((p) => (
          <ProjectCard
            title={p.data.title}
            tagline={p.data.tagline}
            status={p.data.status}
            layer={p.data.layer}
            category={p.data.category}
            architecture={p.data.architecture}
            href={`/projects/${p.slug}/`}
            permissionLevel={p.data.permissionLevel}
          />
        ))}
      </div>
    </section>

    <section class="home-doctrine">
      <h2 class="section-label">Doctrine</h2>
      <p>
        Operational infrastructure bridging software systems and compliance bounds —
        deduplication pipelines, routing engines, and administrative frameworks.
      </p>
    </section>

    <footer class="home-footer">
      <p>© 2026 Shane Turon · <a href="/projects/">Gallery</a> · <a href="/status/">Status</a></p>
    </footer>
  </div>
</body>
</html>

<style>
  .home-wrap {
    max-width: 1100px;
  }
  .home-hero {
    margin-bottom: 2.5rem;
  }
  .home-kicker {
    color: var(--accent, #38bdf8);
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    margin: 0 0 0.5rem;
  }
  .home-hero h1 {
    font-size: 2.25rem;
    margin: 0 0 0.75rem;
    letter-spacing: -0.02em;
  }
  .home-lead {
    color: var(--muted);
    font-size: 1.05rem;
    max-width: 42rem;
    margin: 0 0 1.25rem;
  }
  .home-launch {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem 1.25rem;
    font-size: 0.9rem;
    font-weight: 500;
  }
  .home-launch a {
    color: var(--accent, #38bdf8);
    text-decoration: none;
  }
  .home-launch a:hover {
    text-decoration: underline;
  }
  .home-launch-primary {
    background: var(--accent, #38bdf8);
    color: #0a0a0a !important;
    padding: 0.5rem 1rem;
    border-radius: 4px;
    text-decoration: none !important;
  }
  .home-launch-primary:hover {
    opacity: 0.9;
  }
  .section-label {
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--muted);
    border-bottom: 1px solid var(--border);
    padding-bottom: 0.5rem;
    margin: 0 0 1.25rem;
  }
  .home-doctrine p {
    color: var(--muted);
    font-size: 1rem;
    max-width: 40rem;
  }
  .home-footer {
    margin-top: 3rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--border);
    color: var(--muted);
    font-size: 0.85rem;
    text-align: center;
  }
  .home-footer a {
    color: var(--accent);
  }
</style>
