---
import { getCollection } from "astro:content";
import CinematicHero from "../components/mission/CinematicHero.astro";
import CaseFileFeed from "../components/mission/CaseFileFeed.astro";
import "../styles/tokens.css";

const projects = (await getCollection("projects", ({ data }) => !data.draft)).sort(
  (a, b) => a.data.order - b.data.order,
);
const liveCount = projects.filter((p) => p.data.status === "NOW" || p.data.status === "PILOT").length;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Shane Turon | Mission Control</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
</head>
<body class="mission-body">
  <CinematicHero
    title="Shane Turon"
    subtitle="Operational infrastructure for regulated practice, professional billing recovery, and CONTROL TOWER orchestration. Aerospace-grade presentation — Spine logic unchanged."
    liveCount={liveCount}
    totalCount={projects.length}
  />
  <CaseFileFeed projects={projects} />
  <footer class="mission-footer">
    <p>© 2026 Shane Turon · Mission Control UI (RE-EXP-FERRARI-01) · <a href="/status/" style="color: var(--accent)">Status</a></p>
  </footer>
</body>
</html>
