---
import { getCollection } from "astro:content";
import D1GalleryBridge from "../../components/gallery/D1GalleryBridge";
import ProjectCard from "../../components/gallery/ProjectCard.astro";
import type { Role } from "../../lib/auth/roles";
import "../../styles/tokens.css";

const viewerRole = (Astro.url.searchParams.get("role") ?? "PROFESSIONAL_USER") as Role;
const all = await getCollection("projects", ({ data }) => !data.draft);
const projects = all.sort((a, b) => a.data.order - b.data.order);
const staticSlugs = projects.map((p) => p.slug);
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>ShipYard Gallery — Shane Turon</title>
</head>
<body class="gallery-body">
  <div class="gallery-wrap">
    <a class="back-link" href="/">← shaneturon.ca</a>
    <h1>ShipYard Gallery</h1>
    <p class="tagline">
      Modular execution portfolio — high signal, restrained presentation.
      D1 cards load without redeploy (<code>?role=BACKEND_ADMIN</code> reveals hidden).
    </p>
    <div class="gallery-grid">
      {projects.map((p) => (
        <ProjectCard
          title={p.data.title}
          tagline={p.data.tagline}
          status={p.data.status}
          layer={p.data.layer}
          category={p.data.category}
          architecture={p.data.architecture}
          href={`/projects/${p.slug}/`}
          permissionLevel={p.data.permissionLevel}
          viewerRole={viewerRole}
        />
      ))}
      <D1GalleryBridge client:load role={viewerRole} excludeSlugs={staticSlugs} />
    </div>
  </div>
</body>
</html>

<style>
  h1 {
    font-size: 1.75rem;
    font-weight: 600;
    margin: 1rem 0 0.5rem;
  }
  .tagline {
    color: var(--muted);
    margin-bottom: 2rem;
    font-size: 0.95rem;
  }
</style>
