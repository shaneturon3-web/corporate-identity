---
import type { WritingEntry } from "../../lib/writing/posts";
import { formatWritingDate, postHref } from "../../lib/writing/posts";
import { CATEGORY_LABELS } from "../../lib/writing/categories";

interface Props {
  entry: WritingEntry;
  showCategory?: boolean;
}

const { entry, showCategory = true } = Astro.props;
const { title, date, category, summary, tags, language } = entry.data;
const href = postHref(entry);
---
<article class="writing-card">
  <a href={href}>
    <p class="writing-card-meta">
      {formatWritingDate(date, language)}
      {showCategory && ` · ${CATEGORY_LABELS[category]}`}
      {language !== "en" && ` · ${language}`}
    </p>
    <h2>{title}</h2>
    <p>{summary}</p>
    {
      tags.length > 0 && (
        <div class="writing-tags">
          {tags.map((tag) => (
            <span class="writing-tag">{tag}</span>
          ))}
        </div>
      )
    }
  </a>
</article>
