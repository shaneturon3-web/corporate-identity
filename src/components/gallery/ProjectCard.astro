---
import StatusBadge from "./StatusBadge.astro";
import type { ProjectStatus } from "../../lib/spine/types";
import type { PermissionLevel } from "../../lib/auth/roles";
import { roleMeetsPermission, type Role } from "../../lib/auth/roles";
import { layerLabel, type ArchitectureLayer } from "../../lib/gallery/layer-labels";

interface Props {
  title: string;
  tagline: string;
  status: ProjectStatus;
  layer?: ArchitectureLayer;
  architecture: string[];
  href: string;
  permissionLevel?: PermissionLevel;
  viewerRole?: Role;
  category?: string;
}
const {
  title,
  tagline,
  status,
  layer = 2,
  architecture,
  href,
  permissionLevel = "PUBLIC",
  viewerRole = "PROFESSIONAL_USER",
  category,
} = Astro.props;

const visible = roleMeetsPermission(viewerRole, permissionLevel);
---
{visible && (
<article class="project-card">
  <header class="card-head">
    <div class="icon-node" aria-hidden="true"></div>
    <div class="card-badges">
      <span class="layer-badge">{layerLabel(layer)}</span>
      {category && <span class="layer-badge">{category}</span>}
      <StatusBadge status={status} />
    </div>
  </header>
  <h3 class="card-title"><a href={href}>{title}</a></h3>
  <p class="card-tagline">{tagline}</p>
  <ul class="card-arch">
    {architecture.map((line) => <li>{line}</li>)}
  </ul>
  <a class="card-cta" href={href}>View case file →</a>
</article>
)}

<style>
  .project-card {
    background: var(--surface, #1a1a1a);
    border: 1px solid var(--border, #2a2a2a);
    padding: 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    min-height: 100%;
  }
  .card-head {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
  }
  .card-badges {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 0.35rem;
  }
  .layer-badge {
    font-size: 0.6rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--muted, #94a3b8);
    border: 1px solid var(--border, #2a2a2a);
    padding: 0.15rem 0.4rem;
    border-radius: 2px;
  }
  .icon-node {
    width: 2rem;
    height: 2rem;
    border: 2px solid #94a3b8;
    border-radius: 4px;
    transform: rotate(45deg);
    opacity: 0.7;
  }
  .card-title {
    margin: 0;
    font-size: 1.1rem;
    font-weight: 600;
  }
  .card-title a {
    color: var(--text, #f5f5f5);
    text-decoration: none;
  }
  .card-tagline {
    margin: 0;
    color: #94a3b8;
    font-size: 0.9rem;
    line-height: 1.45;
  }
  .card-arch {
    margin: 0;
    padding-left: 1.1rem;
    color: #cbd5e1;
    font-size: 0.8rem;
    flex: 1;
  }
  .card-cta {
    color: #e2e8f0;
    font-size: 0.85rem;
    font-weight: 500;
    text-decoration: none;
  }
  .card-cta:hover {
    text-decoration: underline;
  }
</style>
