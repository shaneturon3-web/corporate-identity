---
const { frontmatter } = Astro.props;
import '../styles/psynova-blueprint.css';
---
<!DOCTYPE html>
<html lang="en">
<head>
	<meta charset="utf-8" />
	<meta name="viewport" content="width=device-width, initial-scale=1.0" />
	<meta name="robots" content="index, follow" />
	<title>{frontmatter.title} | Shane Turon</title>
</head>
<body class="spec-body">
	<div class="spec-wrap">
		<nav class="spec-nav">
			<a href="/">← shaneturon.ca</a>
		</nav>
		<article class="spec-article">
			<slot />
		</article>
	</div>
</body>
</html>
